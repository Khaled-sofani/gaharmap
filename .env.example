# Database Configuration for GAHAR Dashboard Deployment
# Duplicate this file and rename to .env (if using a system that supports .env like Railway/Render)
# On PythonAnywhere, you will set these in the "WSGI Configuration" file or "Web" configuration.

DB_HOST=yourusername.mysql.pythonanywhere-services.com
DB_USER=yourusername
DB_PASS=your-mysql-password
DB_NAME=yourusername$gis
FLASK_APP=app.py
FLASK_DEBUG=0
